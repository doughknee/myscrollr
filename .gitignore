.git
.env
# Cache file written by @sentry/vite-plugin during source map upload.
.env.sentry-build-plugin
target/
# Cargo.lock is ignored by default for the rest of the workspace (Rust
# convention for libraries — re-resolution per build is fine when the
# crate is consumed as a dependency). The desktop binary is a different
# story: it's a deployable application, and CI was non-deterministically
# resolving Tauri to 2.11.0 while the npm side stayed at 2.10.1, breaking
# the major.minor match check. Commit the desktop binary's lockfile so
# CI gets the same versions every build. The exception below opts it
# back in.
Cargo.lock
!desktop/src-tauri/Cargo.lock
.log
acme_cache/
release/
logs/
node_modules
.DS_Store
dist
dist-ssr
*.local
count.txt
.nitro
.tanstack
.wrangler
.opencode/
.claude/
__pycache__/
*.pyc
.venv/
channels/sports/api/scrollr-sports
channels/finance/api/scrollr-finance
channels/rss/api/scrollr-rss
channels/fantasy/api/scrollr-fantasy
# Compiled Go binaries inside any channel api/ directory — `go build` in a
# channel's api/ drops an executable named after the module (e.g. sports_api,
# finance_api, rss_api, fantasy_api). The wildcard keeps them all out of git
# regardless of what the local dev names the output file.
channels/*/api/*_api
channels/sports/api/sports_api
scaling-changes/
.worktrees/
.superpowers/
# Ad-hoc scratch data (email lists, test payloads, etc.) that must never
# be committed — contains PII.
scripts/*.json

# Raw hero screenshots are the SOURCE files for the optimize script.
# Optimized WebP outputs in myscrollr.com/public/screenshots/hero/ ARE
# committed; the raw PNGs (typically 700KB-1.4MB each, 8 files = ~7MB)
# stay out of git. See myscrollr.com/SCREENSHOTS.md.
scrollr_screenshots/

# Active session handoffs — rolling local state per the global AGENTS.md
# convention. Specs and plans under docs/superpowers/ remain committed
# as engineering history; only the in-flight handoff notes are local.
docs/superpowers/handoffs/

# Generated by scripts/fetch-latest-version.mjs at build time. Bakes in
# the latest desktop version for the auto-download URLs without making
# a runtime fetch (CORS-blocked from the browser).
myscrollr.com/src/lib/latestVersion.generated.ts
