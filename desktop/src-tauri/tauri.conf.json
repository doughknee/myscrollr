{
  "productName": "Scrollr",
  "version": "1.0.9",
  "identifier": "com.scrollr.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5174",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "resources": ["../../LICENSE"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": [],
      "entitlements": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNEEzQ0NFNUE1MEMwQjYKUldTMndGQmF6anhLNnZPTnlZa1N2cHc4K1BUSkMwLzI5Qkl0dFhmeS9mbUlqM1lTNjZuQWFnNzQK",
      "endpoints": [
        "https://github.com/brandon-relentnet/myscrollr/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "ticker",
        "title": "Scrollr Ticker",
        "width": 1920,
        "height": 228,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": true,
        "visible": false
      },
      {
        "label": "main",
        "url": "app.html",
        "title": "Scrollr",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": false,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*; img-src 'self' data: blob: https://*; worker-src 'self' blob:",
      "capabilities": ["main-capability", "ticker-capability"]
    }
  }
}
